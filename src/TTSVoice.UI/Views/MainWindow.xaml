<Window x:Class="TTSVoice.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TTSVoice.UI"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TextBox VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,10,0,0" TextWrapping="Wrap" Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}" Width="200" Height="383"/>
        <Button Content="Button" HorizontalAlignment="Left" VerticalAlignment="Top" Command="{Binding SpeakCommand}" Margin="221,373,0,0"/>
        <ComboBox ItemsSource="{Binding Devices}" SelectedIndex="{Binding SelectedDeviceIndex}" HorizontalAlignment="Left" Margin="221,10,0,0" VerticalAlignment="Top" Width="200"/>


    </Grid>
</Window>
