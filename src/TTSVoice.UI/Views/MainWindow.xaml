<Window x:Class="TTSVoice.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TTSVoice.UI"
        mc:Ignorable="d"
        Title="TTSVoice" Height="440" Width="450" Background="{StaticResource Brush.Window.Background}" ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <Grid Width="410" Height="380" Margin="10" HorizontalAlignment="Center" VerticalAlignment="Center">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="200" />
        </Grid.ColumnDefinitions>
        
        <TextBox Grid.Column="0" Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap"/>

        <StackPanel Grid.Column="2">
            <StackPanel Margin="0,0,0,10" VerticalAlignment="Top">
                <TextBlock Text="MAIN OUTPUT" Margin="0,0,0,5"/>
                <ComboBox Width="200" Margin="0,0,0,5" ItemsSource="{Binding Devices}" SelectedIndex="{Binding SelectedOutputIndex}" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                <DockPanel>
                    <TextBlock Text="Vol:" Margin="0,0,5,0"/>
                    <Slider Value="{Binding OutputVolume}" Maximum="200" VerticalAlignment="Center"/>
                </DockPanel>
            </StackPanel>

            <StackPanel Grid.Column="2" Margin="0,0,0,10" VerticalAlignment="Top">
                <DockPanel Margin="0,0,0,5">
                    <TextBlock Text="MONITORING" IsEnabled="{Binding IsMonitoringEnabled}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <CheckBox IsChecked="{Binding IsMonitoringEnabled}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </DockPanel>
                <ComboBox ItemsSource="{Binding Devices}" SelectedIndex="{Binding SelectedMonitorIndex}" IsEnabled="{Binding IsMonitoringEnabled}" Width="200" Margin="0,0,0,5" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                <DockPanel IsEnabled="{Binding IsMonitoringEnabled}">
                    <TextBlock Text="Vol:" Margin="0,0,5,0"/>
                    <Slider Value="{Binding MonitorVolume}" Maximum="200" VerticalAlignment="Center"/>
                </DockPanel>
            </StackPanel>
        </StackPanel>
        <Button Grid.Column="2" Content="Speak" Command="{Binding SpeakCommand}" Height="36" VerticalAlignment="Bottom"/>
    </Grid>
</Window>
