<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- ================================================================== -->
    <!-- STATIC -->
    <!-- ================================================================== -->
    <Color x:Key="Color.Static.Background">#FF222327</Color>
    <Color x:Key="Color.Static.Border">#FF3F3F46</Color>
    <Color x:Key="Color.Static.Text">#FFFFFFFF</Color>

    <SolidColorBrush x:Key="Brush.Static.Background" Color="{StaticResource Color.Static.Background}"/>
    <SolidColorBrush x:Key="Brush.Static.Border" Color="{StaticResource Color.Static.Border}"/>
    <SolidColorBrush x:Key="Brush.Static.Text" Color="{StaticResource Color.Static.Text}"/>


    <!-- ================================================================== -->
    <!-- DISABLED -->
    <!-- ================================================================== -->
    <Color x:Key="Color.Disabled.Background">#FF2A2A2E</Color>
    <Color x:Key="Color.Disabled.Border">#FF323236</Color>
    <Color x:Key="Color.Disabled.Text">#FF71717A</Color>

    <SolidColorBrush x:Key="Brush.Disabled.Background" Color="{StaticResource Color.Disabled.Background}"/>
    <SolidColorBrush x:Key="Brush.Disabled.Border" Color="{StaticResource Color.Disabled.Border}"/>
    <SolidColorBrush x:Key="Brush.Disabled.Text" Color="{StaticResource Color.Disabled.Text}"/>


    <!-- ================================================================== -->
    <!-- MOUSE OVER -->
    <!-- ================================================================== -->
    <Color x:Key="Color.MouseOver.Background">#FF2D2E33</Color>
    <Color x:Key="Color.MouseOver.Border">#FF52525B</Color>
    <Color x:Key="Color.MouseOver.Text">#FFD4D4D4</Color>

    <SolidColorBrush x:Key="Brush.MouseOver.Background" Color="{StaticResource Color.MouseOver.Background}"/>
    <SolidColorBrush x:Key="Brush.MouseOver.Border" Color="{StaticResource Color.MouseOver.Border}"/>
    <SolidColorBrush x:Key="Brush.MouseOver.Text" Color="{StaticResource Color.MouseOver.Text}"/>


    <!-- ================================================================== -->
    <!-- PRESSED -->
    <!-- ================================================================== -->
    <Color x:Key="Color.Pressed.Background">#FF18181B</Color>
    <Color x:Key="Color.Pressed.Border">#FF3A3A40</Color>
    <Color x:Key="Color.Pressed.Text">#FFAAAAAA</Color>

    <SolidColorBrush x:Key="Brush.Pressed.Background" Color="{StaticResource Color.Pressed.Background}"/>
    <SolidColorBrush x:Key="Brush.Pressed.Text" Color="{StaticResource Color.Pressed.Text}"/>


    <!-- ================================================================== -->
    <!-- SELECTION -->
    <!-- ================================================================== -->
    <Color x:Key="Color.Selection.Background">#FF95B3C7</Color>
    <Color x:Key="Color.Selection.Border">#FF68879C</Color>

    <SolidColorBrush x:Key="Brush.Selection.Background" Color="{StaticResource Color.Selection.Background}"/>
    <SolidColorBrush x:Key="Brush.Selection.Border" Color="{StaticResource Color.Selection.Border}"/>

    <!-- ================================================================== -->
    <!-- OTHER -->
    <!-- ================================================================== -->

    <SolidColorBrush x:Key="Brush.Window.Background" Color="#FF18181B"/>
    
</ResourceDictionary>